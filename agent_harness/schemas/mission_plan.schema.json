{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RobotCollabMissionPlan",
  "type": "object",
  "required": ["intent", "operator_id", "steps"],
  "properties": {
    "trace_id": { "type": "string" },
    "intent": {
      "type": "string",
      "enum": ["deliver_tool", "pause_arm", "resume_arm", "emergency_stop", "query_state"]
    },
    "mode": {
      "type": "string",
      "enum": ["dry-run", "execute"]
    },
    "operator_id": { "type": "string" },
    "tool_id": { "type": "string" },
    "target_station": { "type": "string" },
    "safety": {
      "type": "object",
      "properties": {
        "requires_face_auth": { "type": "boolean" },
        "requires_handover_confirmation": { "type": "boolean" },
        "stop_on_open_palm": { "type": "boolean" }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill", "action", "args"],
        "properties": {
          "skill": { "type": "string" },
          "action": { "type": "string" },
          "args": { "type": "object" },
          "reason": { "type": "string" },
          "timeout_sec": { "type": "number" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
